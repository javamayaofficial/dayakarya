# ============================================================
#  DAYAKARYA - Environment Configuration
#  Platform SaaS Creator Economy Indonesia
# ============================================================

APP_NAME=Dayakarya
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://dayakarya.id
APP_LOCALE=id

# ------------------------------------------------------------
#  DATABASE (MySQL / MariaDB)
# ------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dayakarya
DB_USERNAME=dayakarya_user
DB_PASSWORD=

# ------------------------------------------------------------
#  SESSION / CACHE / QUEUE
# ------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

# ------------------------------------------------------------
#  FILESYSTEM (local untuk awal, S3-compatible saat scale)
# ------------------------------------------------------------
FILESYSTEM_DISK=public
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=
# AWS_ENDPOINT=

# ============================================================
#  MATRIKS INTEGRASI - pilih SATU provider utama per kategori
# ============================================================

# ---- PAYMENT ------------------------------------------------
# Provider utama: duitku | Alternatif: midtrans, xendit | Fallback: manual
PAYMENT_PROVIDER=duitku

# Duitku (utama - preferensi Dayakarya)
DUITKU_MERCHANT_CODE=
DUITKU_API_KEY=
DUITKU_ENV=sandbox
# sandbox: https://sandbox.duitku.com | production: https://passport.duitku.com
DUITKU_CALLBACK_URL="${APP_URL}/api/v1/payments/duitku/callback"
DUITKU_RETURN_URL="${APP_URL}/wallet/topup/selesai"

# Midtrans (alternatif)
# MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY=
# MIDTRANS_IS_PRODUCTION=false

# Xendit (alternatif)
# XENDIT_SECRET_KEY=

# Manual Transfer / QRIS (fallback)
MANUAL_BANK_NAME="BCA"
MANUAL_BANK_ACCOUNT="1234567890"
MANUAL_BANK_HOLDER="Yayasan Pondok Daya Cipta Nusantara"
MANUAL_QRIS_IMAGE_URL=
SUPPORT_WHATSAPP_NUMBER="62800000000"
SUPPORT_EMAIL="admin@dayakarya.id"

# ---- WHATSAPP ----------------------------------------------
# Provider utama: fonnte | Alternatif: onesender, starsender
WA_PROVIDER=fonnte
FONNTE_TOKEN=
FONNTE_URL=https://api.fonnte.com/send
# ONESENDER_TOKEN=
# ONESENDER_URL=
# STARSENDER_TOKEN=
# STARSENDER_URL=

# ---- EMAIL --------------------------------------------------
# Provider utama: mailketing | Alternatif: kirimemail
EMAIL_PROVIDER=mailketing
MAILKETING_API_TOKEN=
MAILKETING_FROM_EMAIL=noreply@dayakarya.id
MAILKETING_FROM_NAME=Dayakarya
MAILKETING_URL=https://api.mailketing.co.id/api/v1/send
# KIRIMEMAIL_TOKEN=
# KIRIMEMAIL_DOMAIN=

# ---- SOCIAL AUTH --------------------------------------------
# Google OAuth untuk login/register cepat
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ============================================================
#  EKONOMI PLATFORM (bisa diubah di Admin > Pengaturan)
# ============================================================
# Kurs konversi: 1 Credit = berapa Rupiah
CREDIT_RATE_RUPIAH=100
# Bagi hasil royalti kreator (persen dari harga unlock)
ROYALTY_CREATOR_PERCENT=70
# Komisi affiliate (persen dari harga unlock)
AFFILIATE_COMMISSION_PERCENT=10
# Minimum penarikan (rupiah)
WITHDRAW_MINIMUM=50000
# Fee penarikan (rupiah)
WITHDRAW_FEE=2500

# ------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=error
